###                        Docker Compose                                   ###
###############################################################################
# build-docker-compose-file
build-dcf:
	$(GO) run cmd/ci/main.go

start-dc:
	docker compose up -d
	docker compose ps

stop-dc:
	docker compose down --volumes

.PHONY: build-dcf start-dc stop-dc

precompile:
	@cd x/evm/precompiles && sh compile.sh

verify:
	@cd solidity && node verify.js
